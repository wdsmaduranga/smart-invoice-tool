# Copy this file to .env.local and fill in your values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://smartinvoicetool.com/
NEXT_PUBLIC_APP_NAME="Invoice Generator Hub"
NEXT_PUBLIC_APP_DESCRIPTION="Professional invoice creation tool with PDF export functionality"

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_google_analytics_id
NEXT_PUBLIC_HOTJAR_ID=your_hotjar_id

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=1